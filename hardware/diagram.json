{
  "version": 1,
  "author": "ULAB_Anonymous_3.0",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    
    /* 3x LEDs for Light Indicators */
    { "type": "wokwi-led", "id": "led_light1", "top": -160, "left": -90, "attrs": { "color": "yellow" } },
    { "type": "wokwi-led", "id": "led_light2", "top": -160, "left": 0, "attrs": { "color": "yellow" } },
    { "type": "wokwi-led", "id": "led_light3", "top": -160, "left": 90, "attrs": { "color": "yellow" } },
    
    /* 3x 330 Ohm Current Limiting Resistors */
    { "type": "wokwi-resistor", "id": "r1", "top": -90, "left": -90, "attrs": { "value": "330" } },
    { "type": "wokwi-resistor", "id": "r2", "top": -90, "left": 0, "attrs": { "value": "330" } },
    { "type": "wokwi-resistor", "id": "r3", "top": -90, "left": 90, "attrs": { "value": "330" } },
    
    /* 2x Relays for Fan Controls (Placed low to prevent overlap) */
    { "type": "wokwi-relay-module", "id": "relay_fan1", "top": 240, "left": -140, "attrs": {} },
    { "type": "wokwi-relay-module", "id": "relay_fan2", "top": 240, "left": 140, "attrs": {} },
    
    /* Potentiometer simulating ACS712 Current Sensor */
    { "type": "wokwi-potentiometer", "id": "pot_acs712", "top": 240, "left": 0, "attrs": { "label": "ACS712 Current" } }
  ],
  "connections": [
    /* Ground Connections (Black) */
    [ "esp:GND.1", "led_light1:C", "black", [ "v0", "h-20" ] ],
    [ "esp:GND.1", "led_light2:C", "black", [ "v0", "h-10" ] ],
    [ "esp:GND.1", "led_light3:C", "black", [ "v0", "h10" ] ],
    [ "esp:GND.2", "relay_fan1:GND", "black", [] ],
    [ "esp:GND.2", "relay_fan2:GND", "black", [] ],
    [ "esp:GND.2", "pot_acs712:GND", "black", [] ],
    
    /* VCC Power Connections (Red) */
    [ "esp:3V3.1", "relay_fan1:VCC", "red", [] ],
    [ "esp:3V3.1", "relay_fan2:VCC", "red", [] ],
    [ "esp:3V3.1", "pot_acs712:VCC", "red", [] ],
    
    /* LED Signal Lines connected through Resistors */
    [ "led_light1:A", "r1:1", "yellow", [] ],
    [ "led_light2:A", "r2:1", "yellow", [] ],
    [ "led_light3:A", "r3:1", "yellow", [] ],
    [ "esp:19", "r1:2", "orange", [] ],
    [ "esp:21", "r2:2", "orange", [] ],
    [ "esp:22", "r3:2", "orange", [] ],
    
    /* Relay Control Signal Lines (Blue) */
    [ "esp:5", "relay_fan1:IN", "blue", [] ],
    [ "esp:18", "relay_fan2:IN", "blue", [] ],
    
    /* Current Sensor Analog Signal Line (Green) to GPIO 34 */
    [ "esp:34", "pot_acs712:SIG", "green", [] ]
  ],
  "dependencies": {}
}
